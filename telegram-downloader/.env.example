# Telegram API Credentials (REQUIRED)
# Get these from https://my.telegram.org under "API Development Tools"
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Session Configuration
# This is the name of the session file that stores your authentication
SESSION_NAME=media_downloader

# Download Configuration
# Path inside the container where files will be downloaded
DOWNLOAD_PATH=/app/downloads

# How many historical messages to scan per chat
# Set to 0 to skip history scanning and only monitor new messages
MAX_HISTORY_MESSAGES=1000

# Telegram API Settings
# Auto-sleep for flood waits shorter than this many seconds
FLOOD_SLEEP_THRESHOLD=60

# Media Types to Download
# Set to true or false for each type
DOWNLOAD_PHOTOS=true
DOWNLOAD_VIDEOS=true
DOWNLOAD_DOCUMENTS=false
